# Copy this file to .env.local and uncomment the relevant line for your deployment.

# VITE_ASYNC_DONATIONS controls how the workflow handles donation responses from the host.
#
# false (default, unset): fire-and-forget mode.
#   Compatible with D3I's self-hosted mono, which does not send a reply after receiving
#   a donation. The workflow posts the data and moves on immediately.
#
# true: async mode.
#   Compatible with Eyra's hosted mono (as of Jan 2026, commit f1395c378), which stores
#   donations via HTTP POST and replies with DonateSuccess or DonateError via
#   MessageChannel. The workflow awaits the reply before continuing, and Python receives
#   the outcome as a PayloadResponse (success, key, status, optional error).
#
# Leave unset (or set to false) when deploying via D3I's mono.
# Set to true when deploying via Eyra's hosted Next platform.

# VITE_ASYNC_DONATIONS=true

# VITE_LANGUAGE sets the locale used in standalone/dev mode (default: en).
# In production the locale is provided by the host page.
# Valid values: en, nl, de, es, lt, ro
#
# VITE_LANGUAGE=nl
